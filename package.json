{
  "name": "kavach-ai",
  "version": "1.0.0",
  "private": true,
  "description": "KAVACH AI - Explainable Crime Intelligence Copilot for Karnataka State Police",
  "scripts": {
    "setup": "npm install && npm run build:client",
    "seed": "npx ts-node database/seed.ts",
    "dev:server": "npx ts-node server/src/app.ts",
    "dev:client": "npm --prefix client run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "npm --prefix client run build",
    "test": "npx ts-node tests/run-all.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sql.js": "^1.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.9",
    "@types/sql.js": "^1.4.9",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
